---
required_variables:
  - test_name
  - display_pattern
  - assertion_kinds
  - assertion_kwargs
defaults:
  capture_delay_ms: 500
  retries: 3
metadata:
  purpose: "Vision multi-assertion test — show pattern, capture, then run a sequence of assertion calls on the captured image. Composes setup_preamble + pattern_capture from the kit; the {% for %} loop body emits the same hitl_assert.<kind>(image, <kwargs>) call shape one per item."
---
@<primitives/setup_preamble.j2>
@<primitives/pattern_capture.j2>
{% for kind in assertion_kinds %}
    hitl_assert.{{ kind }}(image, {{ assertion_kwargs[loop.index0] }})
{% endfor %}
