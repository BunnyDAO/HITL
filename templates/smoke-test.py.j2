---
required_variables:
  - test_name
defaults:
  display_pattern: smoke
metadata:
  purpose: "Smoke test — minimal 'device alive' check that the fixture wiring works. Composes from the primitives kit (setup_preamble) plus an inline assertion."
---
@<primitives/setup_preamble.j2>
    display.show("{{ display_pattern }}")
    image = camera.capture()
    hitl_assert.pixel_intensity_above(image, threshold=0)
