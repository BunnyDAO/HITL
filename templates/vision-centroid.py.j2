---
required_variables:
  - test_name
  - display_pattern
  - target_x
  - target_y
  - tolerance_px
defaults:
  capture_delay_ms: 500
  retries: 3
metadata:
  purpose: "Vision centroid alignment test — show a pattern, capture an image, assert the centroid lands within tolerance of a target pixel. Composes from the kit: setup_preamble + pattern_capture + assert_centroid."
---
@<primitives/setup_preamble.j2>
@<primitives/pattern_capture.j2>
@<primitives/assert_centroid.j2>
